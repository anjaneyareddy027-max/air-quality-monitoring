# OpenAQ v3 API key - free signup at https://explore.openaq.org/register
OPENAQ_API_KEY=

# Local dev paths (defaults match config/settings.py if unset)
RAW_DATA_DIR=data/raw
BATCH_VIEW_DIR=data/batch-view
SPEED_VIEW_DIR=data/speed-view
CHECKPOINT_DIR=data/checkpoints

# Sink selection: "local" (default, JSON-lines on disk) or "kinesis"
INGEST_SINK=local

# Only needed when INGEST_SINK=kinesis
AWS_REGION=eu-west-1
KINESIS_STREAM_NAME=air-quality-raw
